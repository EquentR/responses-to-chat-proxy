# Upstream Chat Completions compatible endpoint.
# If the upstream exposes /v1/chat/completions, set the base URL to include /v1.
UPSTREAM_BASE_URL=https://api.openai.com/v1
UPSTREAM_API_KEY=sk-your-upstream-key

# Optional client-facing API key. Leave empty to disable proxy-side auth.
PROXY_API_KEY=

# Optional model override for all forwarded requests.
MODEL_OVERRIDE=

# Server and upstream options.
HOST=0.0.0.0
PORT=8000
REQUEST_TIMEOUT_SECONDS=120
STREAM_TIMEOUT_SECONDS=300
VERIFY_SSL=true
LOG_LEVEL=info

# Optional. Overrides auto-inferred reasoning parameter form sent upstream.
# Empty (default): infer from model name / base URL (OpenAI/GPT-5 -> reasoning_effort,
# DeepSeek -> thinking+reasoning_effort, GLM/Kimi/MiMo -> thinking_only, Qwen -> enable_thinking,
# MiniMax -> reasoning_split, OpenRouter -> reasoning.effort object).
# Set explicitly when using a custom Chat-Completions upstream whose reasoning
# contract differs from what the model name suggests (e.g. a third-party proxy
# that accepts a top-level reasoning_effort even though the model is glm-5.2).
# Allowed: effort | effort_obj | thinking | thinking_only | enable_thinking | reasoning_split
REASONING_MODE=