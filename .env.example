# Upstream API base URL. This may point at an upstream that speaks
# OpenAI Responses, OpenAI Chat Completions, or Anthropic-compatible Messages.
# If the upstream already exposes a versioned root such as /v1, include it here.
UPSTREAM_BASE_URL=https://api.openai.com/v1
# Use one key, or multiple comma-separated keys for the same upstream.
# When one of multiple configured keys returns 429, it is cooled down and the
# request retries with another configured key.
UPSTREAM_API_KEY=sk-your-upstream-key
UPSTREAM_KEY_COOLDOWN_SECONDS=30

# Optional explicit models endpoint used for route discovery.
UPSTREAM_MODELS_URL=

# Optional client-facing API key. Leave empty to disable proxy-side auth.
PROXY_API_KEY=

# Optional model override for all forwarded requests.
MODEL_OVERRIDE=

# Route discovery behavior.
# Allowed: lazy | startup | off
ROUTE_DETECTION=lazy

# In-memory route table TTL in seconds.
ROUTE_TABLE_TTL_SECONDS=1800

# Reserved for future route-table persistence support.
ROUTE_TABLE_PERSIST=false

# Allow minimal generation probes when metadata is insufficient.
ROUTE_PROBE_GENERATION=false

# Inject cache_control breakpoints on Responses -> Chat conversion paths only.
# Native Responses passthrough requests are forwarded unchanged.
CACHE_OPTIMIZER=false
CACHE_OPTIMIZER_TTL=1h

# Server and upstream options.
HOST=0.0.0.0
PORT=8000
REQUEST_TIMEOUT_SECONDS=120
STREAM_TIMEOUT_SECONDS=300
VERIFY_SSL=true
LOG_LEVEL=info

# Optional. Overrides auto-inferred reasoning parameter form sent upstream.
# Empty (default): infer from model name / base URL (OpenAI/GPT-5 -> reasoning_effort,
# DeepSeek -> thinking+reasoning_effort, GLM/Kimi/MiMo -> thinking_only, Qwen -> enable_thinking,
# MiniMax -> reasoning_split, OpenRouter -> reasoning.effort object).
# Set explicitly when using a custom Chat-Completions upstream whose reasoning
# contract differs from what the model name suggests (e.g. a third-party proxy
# that accepts a top-level reasoning_effort even though the model is glm-5.2).
# Allowed: effort | effort_obj | thinking | thinking_only | enable_thinking | reasoning_split
REASONING_MODE=
